# Database
DATABASE_URL="postgresql://user:password@localhost:5432/community_app?schema=public"

# Auth
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# OTP Provider (mock in dev, swap to twilio in production)
OTP_PROVIDER="mock"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Payment (Sprint 3)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Push Notifications (Sprint 2)
FCM_SERVER_KEY=""
FCM_PROJECT_ID=""

# App
NODE_ENV="development"
API_PORT=3000
API_URL="http://localhost:3000"

# Visitor approval timeout (seconds)
VISITOR_APPROVAL_TIMEOUT=90

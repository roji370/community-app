{
  "name": "community-app",
  "version": "0.1.0",
  "private": true,
  "description": "Role-based society management platform — resident, guard, committee",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:migrate": "pnpm --filter @community/db migrate:dev",
    "db:seed": "pnpm --filter @community/db seed",
    "db:studio": "pnpm --filter @community/db studio"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "turbo": "^2.10.2",
    "typescript": "^5.9.3"
  }
}
